# =============================================================================
# AI Crypto Trading Bot — Environment Configuration
# =============================================================================
# Usage:
#   cp .env.example .env
#   Edit .env and replace placeholder values before starting the application.
#
# Security rules:
#   - NEVER commit .env to version control (.gitignore already excludes it).
#   - In production, inject secrets via a secrets manager (Vault, AWS SSM, etc.).
#   - Rotate EXCHANGE_API_SECRET and LIVE_TRADING_CONFIRM_TOKEN regularly.
#   - SecretStr fields (passwords, keys, tokens) are never written to logs.
# =============================================================================


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Human-readable application name shown in logs and health responses.
APP_NAME="AI Crypto Trading Bot"

# Semantic version string, reflected in /health and log metadata.
APP_VERSION=0.1.0

# Enable debug mode. MUST be false in production — exposes internal details.
DEBUG=false

# Log verbosity. One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------

# Uvicorn bind host. 0.0.0.0 listens on all interfaces (correct inside Docker).
HOST=0.0.0.0

# Uvicorn bind port. Must be in the range 1024–65535.
PORT=8000

# Comma-separated list of CORS allowed origins for the Next.js frontend.
# JSON array syntax is accepted by Pydantic Settings.
# Example for production: '["https://trading.yourdomain.com"]'
ALLOWED_ORIGINS=["http://localhost:3000"]


# -----------------------------------------------------------------------------
# API Authentication
# -----------------------------------------------------------------------------

# Master switch for API key authentication.
# false = all endpoints open (local development only).
# true  = all non-public endpoints require a valid X-API-Key header.
# MUST be true in any internet-accessible deployment.
REQUIRE_API_AUTH=false

# SHA-256 hex digest of the API key that clients must supply in X-API-Key.
# NEVER store the raw key here — only the 64-character lowercase hex hash.
# Generate the hash:
#   Linux/macOS : echo -n "my-secret-key" | sha256sum | awk '{print $1}'
#   Python      : python -c "import hashlib; print(hashlib.sha256(b'my-secret-key').hexdigest())"
# Leave empty when REQUIRE_API_AUTH=false.
API_KEY_HASH=


# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------

# Master switch for per-IP rate limiting. MUST be true in production.
RATE_LIMIT_ENABLED=true

# Rate limit for authentication failures per IP address.
# Deliberately tight to prevent brute-force API key guessing.
# Uses limits library syntax: '<count>/<period>' (period: second|minute|hour|day)
RATE_LIMIT_AUTH_FAILURES=5/minute

# Rate limit for write endpoints (POST, PUT, PATCH, DELETE) per IP.
RATE_LIMIT_WRITE=30/minute

# Rate limit for read endpoints (GET) per IP.
# Set high enough to support dashboard polling (typically every 1–5 seconds).
RATE_LIMIT_READ=120/minute

# Number of trusted reverse proxy hops between the internet and this service.
# 0 (default) = direct connection — X-Forwarded-For is ignored entirely.
#               This is the safe default; it prevents IP spoofing via forged XFF headers.
# 1           = single nginx / ALB / Cloudflare proxy in front of the app.
# SECURITY: Never set higher than the actual number of controlled proxy hops.
TRUSTED_PROXY_COUNT=0


# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------

# Enable the Prometheus /metrics scrape endpoint.
# true  = GET /metrics returns Prometheus text exposition format.
# false = endpoint is not mounted (minimal deployments).
PROMETHEUS_ENABLED=true


# -----------------------------------------------------------------------------
# Database (PostgreSQL via asyncpg)
# -----------------------------------------------------------------------------

# Option A: provide a full DSN directly.
# Must use the postgresql+asyncpg:// scheme — required for async support.
# If left empty, the DSN is assembled from the POSTGRES_* variables below.
DATABASE_URL=

# Option B: individual connection parameters (used when DATABASE_URL is empty).
# The application assembles: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_bot
POSTGRES_USER=trading

# REQUIRED — replace with a strong random password before first run.
# Avoid special characters that break DSN strings (%, @, /).
POSTGRES_PASSWORD=changeme

# SQLAlchemy async connection pool configuration.
DB_POOL_SIZE=10          # Number of persistent connections in the pool (1–50)
DB_MAX_OVERFLOW=20       # Additional connections allowed beyond pool size (0–100)
DB_POOL_TIMEOUT=30.0     # Seconds to wait for an available connection before error


# -----------------------------------------------------------------------------
# Redis (optional — caching and job queue)
# -----------------------------------------------------------------------------

# Redis DSN. Leave empty (or omit entirely) to disable Redis integration.
# Format: redis://[:password@]host[:port][/db_number]
# Example: redis://localhost:6379/0
REDIS_URL=


# -----------------------------------------------------------------------------
# Exchange / CCXT
# -----------------------------------------------------------------------------

# CCXT exchange identifier. See https://docs.ccxt.com for supported exchanges.
# Common values: binance | kraken | coinbase | bybit
EXCHANGE_ID=binance

# Exchange API key — required for live trading, optional for paper/backtest.
# This is stored as a SecretStr and is never written to logs or responses.
EXCHANGE_API_KEY=

# Exchange API secret — required for live trading, optional for paper/backtest.
# This is stored as a SecretStr and is never written to logs or responses.
EXCHANGE_API_SECRET=

# Exchange API passphrase — required by some exchanges (e.g. Coinbase legacy keys).
# For Coinbase CDP keys (new format): leave empty, no passphrase needed.
# For Coinbase legacy keys: set to the passphrase chosen during key creation.
# Not required for Binance or Bybit.
EXCHANGE_API_PASSPHRASE=


# -----------------------------------------------------------------------------
# Live Trading Safety Gates
#
# All THREE conditions must be satisfied simultaneously before any real order
# is submitted to the exchange. Failing any single gate keeps the engine in
# paper trading mode.
# -----------------------------------------------------------------------------

# Gate 1 — master enable switch.
# false (default) = paper trading only, regardless of exchange credentials.
# true            = allows real order placement when Gates 2 and 3 also pass.
ENABLE_LIVE_TRADING=false

# Gate 2 — exchange credentials (EXCHANGE_API_KEY + EXCHANGE_API_SECRET above).
# Both must be non-empty. Set them in the Exchange section above.

# Gate 3 — confirmation token providing a second explicit human-intent signal.
# Generate with: openssl rand -hex 32
# Must match the value validated by the execution engine safety check.
LIVE_TRADING_CONFIRM_TOKEN=


# -----------------------------------------------------------------------------
# Risk Defaults (overridable per-run via the API)
# -----------------------------------------------------------------------------

# Maximum number of simultaneously open positions across all symbols. (1–20)
DEFAULT_MAX_OPEN_POSITIONS=3

# Fraction of total equity risked on a single trade. 0.01 = 1%.
# Validator enforces the range (0.0, 0.05].
DEFAULT_PER_TRADE_RISK_PCT=0.01

# Maximum cumulative daily loss as a fraction of starting equity before the
# engine halts all new entries. 0.05 = 5%.
# Validator enforces the range (0.0, 0.25].
DEFAULT_MAX_DAILY_LOSS_PCT=0.05

# Maximum drawdown from the equity high-water mark before the circuit breaker
# fires and suspends all trading. 0.15 = 15%.
# Validator enforces the range (0.0, 0.50].
DEFAULT_MAX_DRAWDOWN_PCT=0.15


# -----------------------------------------------------------------------------
# Next.js UI
# -----------------------------------------------------------------------------

# Base URL the browser uses to reach the FastAPI backend.
# For a reverse-proxy deployment, point this at your public domain.
NEXT_PUBLIC_API_URL=http://localhost:8000


# -----------------------------------------------------------------------------
# ML Auto-Retraining (Sprint 23)
# -----------------------------------------------------------------------------

# Master switch for automatic model retraining.
# false (default) = RetrainingService does not start (safe default).
# true            = RetrainingService polls trade counts and retrains when threshold met.
# Follows the same safety-first convention as ENABLE_LIVE_TRADING.
ML_AUTO_RETRAIN=false

# Minimum number of new closed trades since last training required to trigger
# automatic retraining. Must be >= 10. Default 50 provides ~15-20 samples per
# class with a typical 40/30/30 label distribution. Statistically defensible floor.
ML_MIN_TRADES_FOR_RETRAIN=50

# Minimum test-set accuracy for a retrained model to be activated.
# 0.38 is 5% above the 0.333 random baseline for a 3-class classifier.
# Models below this threshold are saved to disk but not activated.
ML_MIN_ACCURACY_THRESHOLD=0.38

# Maximum model versions kept on disk and in the database per (symbol, timeframe) pair.
# Older inactive versions are pruned after each successful retraining. The active
# model is never pruned. Range: 1–50.
ML_MAX_MODEL_VERSIONS=5

# How often (in minutes) RetrainingService checks trade counts in the database.
# The service sleeps for this interval before each poll. Range: 5–1440.
# Default: 60 minutes (once per hour). Increase for lower-frequency strategies.
ML_RETRAIN_INTERVAL_MINUTES=60


# -----------------------------------------------------------------------------
# Telegram Alerts (optional)
# -----------------------------------------------------------------------------

# Telegram Bot API token obtained from @BotFather.
# Format: <numeric_id>:<alphanumeric_string>
# Leave empty to disable Telegram notifications.
TELEGRAM_BOT_TOKEN=

# Target Telegram chat or group ID.
# Positive integer for direct chats, negative for groups/channels
# (e.g. -100123456789 for a supergroup).
# Leave empty to disable Telegram notifications.
TELEGRAM_CHAT_ID=
