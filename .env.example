# =============================================================================
# .env.example — AI Crypto Trading Bot
#
# USAGE:
#   cp .env.example .env
#   Then fill in all values marked with <CHANGE_ME> before running.
#
# SECURITY:
#   - NEVER commit .env to version control.
#   - .env is listed in .gitignore — verify before pushing.
#   - Rotate EXCHANGE_API_SECRET and LIVE_TRADING_CONFIRM_TOKEN regularly.
#   - In production, inject secrets via your secrets manager (Vault, AWS SSM, etc.)
# =============================================================================


# =============================================================================
# DATABASE — PostgreSQL
# =============================================================================

# Hostname of the postgres container (matches the service name in docker-compose.yml)
POSTGRES_HOST=postgres

# Port exposed by the postgres container
POSTGRES_PORT=5432

# Name of the application database
POSTGRES_DB=trading_bot

# Database user (do not use the postgres superuser in production)
POSTGRES_USER=trading

# Database password — MUST be changed before first run
# Minimum 16 characters; avoid special chars that break DSN strings
POSTGRES_PASSWORD=<CHANGE_ME>

# Composite database URL (optional — if set, overrides individual POSTGRES_* vars above)
# DATABASE_URL=postgresql+asyncpg://trading:<CHANGE_ME>@postgres:5432/trading_bot


# =============================================================================
# CACHE / QUEUE — Redis
# =============================================================================

# Full Redis DSN consumed by the API.
# Pattern: redis://[:password@]host[:port][/db_number]
# Leave password empty if Redis is on an isolated network and no auth is needed.
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# Password for the Redis requirepass directive (matches docker-compose.yml)
# Leave blank to disable Redis authentication (only acceptable on an isolated network)
REDIS_PASSWORD=

# Port exposed by the redis container
REDIS_PORT=6379


# =============================================================================
# API SERVER — FastAPI
# =============================================================================

# Bind address for the uvicorn server inside the container
API_HOST=0.0.0.0

# Port the API listens on (also the Docker host port mapping)
API_PORT=8000

# Uvicorn log level: debug | info | warning | error | critical
LOG_LEVEL=info

# Deployment environment: development | staging | production
# Controls CORS origins, debug tooling, and stack trace exposure
ENVIRONMENT=development

# Enable the Prometheus /metrics endpoint (true | false)
PROMETHEUS_ENABLED=true


# =============================================================================
# API AUTHENTICATION
# =============================================================================

# Master switch for API key authentication.
# false = all endpoints open (local development / testing).
# true  = all non-public endpoints require a valid API key via X-API-Key header.
# MUST be set to "true" in production.
REQUIRE_API_AUTH=false

# SHA-256 hex digest of the valid API key.
# Generate the hash (do NOT store the raw key here):
#   Linux/macOS:  echo -n "my-secret-api-key" | sha256sum | awk '{print $1}'
#   Python:       python -c "import hashlib; print(hashlib.sha256(b'my-secret-api-key').hexdigest())"
# Then give the raw key to API consumers to use in the X-API-Key header.
# Leave empty when REQUIRE_API_AUTH=false.
API_KEY_HASH=


# =============================================================================
# TRADING — Safety gates (read carefully before enabling live trading)
# =============================================================================

# Master switch for live trading.
# MUST be explicitly set to "true" — all other values disable live trading.
# Paper trading and backtesting work regardless of this flag.
ENABLE_LIVE_TRADING=false

# Exchange API credentials — only required when ENABLE_LIVE_TRADING=true.
# Supported exchanges: binance, kraken (via CCXT).
# Recommendation: use READ-ONLY keys for paper/backtest, TRADE keys for live.
# NEVER share or log these values.
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# Secondary confirmation token — a simple extra safeguard against accidental
# live trading activation. The API validates this token at run start.
# Set to a random UUID or passphrase; keep it private.
LIVE_TRADING_CONFIRM_TOKEN=

# Exchange to connect to when live trading is enabled
# Options (CCXT slug): binance, kraken, coinbasepro, bybit
EXCHANGE_ID=kraken

# Default trading pair (symbol) for new strategy runs
DEFAULT_SYMBOL=BTC/USDT

# Default candle timeframe for new strategy runs
# Options: 1m, 5m, 15m, 1h, 4h, 1d
DEFAULT_TIMEFRAME=5m


# =============================================================================
# UI — Next.js frontend
# =============================================================================

# Base URL the browser uses to reach the API.
# In Docker Compose with the default port mapping, this is the host-accessible URL.
# For a reverse-proxy setup, set this to your public domain.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Internal API URL used by the Next.js server for server-side data fetching.
# In Docker Compose, this is the internal service name. Do not change unless
# you rename the api service.
INTERNAL_API_URL=http://api:8000

# Port the Next.js server listens on inside the container
UI_PORT=3000


# =============================================================================
# OBSERVABILITY (optional)
# =============================================================================

# Sentry DSN for error tracking (leave blank to disable)
SENTRY_DSN=

# Telegram bot token for trade/alert notifications (leave blank to disable)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID to send alerts to
TELEGRAM_CHAT_ID=
